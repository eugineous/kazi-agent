# Kazi Backend Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=30d

# OAuth — GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth — Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI
GEMINI_API_KEY=your-gemini-api-key

# M-Pesa / Daraja
MPESA_CONSUMER_KEY=your-safaricom-consumer-key
MPESA_CONSUMER_SECRET=your-safaricom-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_CALLBACK_URL=https://api.kaziagent.com/payments/mpesa/callback
MPESA_ENV=sandbox

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Admin API Key (for programmatic admin access)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=change-this-to-a-long-random-key
