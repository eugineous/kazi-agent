# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/kazi

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=30d

# ── Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── M-Pesa / Daraja ──────────────────────────────────────────
MPESA_CONSUMER_KEY=your-safaricom-consumer-key
MPESA_CONSUMER_SECRET=your-safaricom-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_CALLBACK_URL=https://api.kaziagent.com/payments/mpesa/callback
MPESA_ENV=sandbox        # change to 'production' when live

# ── OAuth ────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
SUPER_ADMIN_EMAIL=your@email.com
FRONTEND_URL=https://kazi-agent.vercel.app

# ── Admin API Key (for Claude Code / programmatic admin access) ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=change-this-to-a-long-random-key
