# Kazi Agent (Electron) Environment Variables
# Optional — most config is in kazi_settings.json

# Override backend URL (default: https://kazi-backend-stzv.onrender.com)
# KAZI_BACKEND_URL=http://localhost:3001

# Gemini API key for local Python agent (optional if using cloud backend)
# GEMINI_API_KEY=your-key-here
